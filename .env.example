# ═══════════════════════════════════════════════════════════════════════
#  NutriAI — Environment Variables (copy to .env and fill in)
# ═══════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────

# Flask secret key (MUST be a long random string in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Google Gemini API key for AI diet plan generation
GEMINI_API_KEY=

# ── Admin Credentials ─────────────────────────────────────────────────

# Admin panel username (no default — MUST be set)
ADMIN_USERNAME=

# Admin panel password (no default — MUST be set, use a strong password)
ADMIN_PASSWORD=

# ── Database (Render PostgreSQL) ──────────────────────────────────────

# Set DATABASE_URL for PostgreSQL on Render
# Leave empty for local SQLite fallback
DATABASE_URL=

# ── Optional ──────────────────────────────────────────────────────────

# Site URL for sitemaps and canonical URLs
SITE_URL=https://nutriai.onrender.com

# Debug mode (NEVER true in production)
DEBUG=False

# ── Google OAuth 2.0 (Optional, sandbox mock fallback if empty) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

